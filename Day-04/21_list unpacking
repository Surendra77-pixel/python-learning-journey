#List Unpacking

fruits = ["apple", "banana", "cherry"]
a, b, c = fruits
print(a) #output: apple - The variable a is assigned the value of the first element of the list fruits, which is "apple".
print(b) #output: banana - The variable b is assigned the value of the second element of the list fruits, which is "banana".
print(c) #output: cherry - The variable c is assigned the value of the third element of the list fruits, which is "cherry".
